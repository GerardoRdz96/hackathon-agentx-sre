# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database
DATABASE_PATH=/app/data/sre.db

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Real Email Notifications via Resend (optional — falls back to DB-only if not set)
RESEND_API_KEY=re_xxxxx
RESEND_FROM=SRE Agent <hello@yourdomain.com>

# Real Telegram Alerts for CRITICAL/HIGH incidents (optional — skipped if not set)
TELEGRAM_BOT_TOKEN=xxxxx
TELEGRAM_CHAT_ID=xxxxx
